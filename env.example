# Polyglot CP - execution engine config.
# Copy to .env and fill in to use Judge0 instead of the keyless local engine.
# Do NOT commit your real .env (it is gitignored).
#
# NOTE: this .env only configures the DEV-SERVER engine (server/runner.ts, used
# in "ローカル dev サーバー" mode). The static build has no backend, so its
# Judge0 connection is set in the UI (右上の Judge0 設定) and stored in
# localStorage - not here. For GitHub Pages project subpaths, build with
# BASE_PATH=/<repo>/ npm run build.

# Set to "true" to route every line through Judge0 instead of the local engine.
# Local engine (keyless) already runs: python, javascript, ruby, perl, bash,
# swift, dart, go, c, cpp, rust, java, and zig (zig is local-only; install the
# zig toolchain to use it - Judge0 CE has no Zig runtime). Judge0 additionally
# unlocks languages not installed locally: php, typescript, kotlin, scala, lua, csharp.
USE_JUDGE0=false

# Judge0 API base URL, e.g. https://judge0-ce.p.rapidapi.com  (RapidAPI)
# or your self-hosted instance, e.g. http://localhost:2358
JUDGE0_URL=

# RapidAPI key + host (only needed for the RapidAPI-hosted Judge0).
# Leave blank for a self-hosted Judge0 that needs no auth.
JUDGE0_KEY=
JUDGE0_HOST=judge0-ce.p.rapidapi.com
