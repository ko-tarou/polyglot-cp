{
  "name": "polyglot-cp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "PoC: a competitive-programming judge where each line of a submission runs in a different language, piped together",
  "scripts": {
    "bundle-problems": "python3 tools/build_static_problems.py",
    "predev": "npm run bundle-problems",
    "dev": "vite",
    "prebuild": "npm run bundle-problems",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
